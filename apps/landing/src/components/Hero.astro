---
const nodes = [
  { label: 'GPT', delay: '0s' },
  { label: 'Claude', delay: '0.8s' },
  { label: 'Gemini', delay: '1.6s' },
  { label: 'DeepSeek', delay: '2.4s' },
  { label: 'Mistral', delay: '3.2s' },
];
---

<section class="relative z-10 pt-24 pb-16 md:pt-28 md:pb-20 overflow-hidden">
  <div class="max-w-wrap mx-auto px-6">
    <div class="grid md:grid-cols-[1.05fr_0.95fr] gap-10 md:gap-14 items-center">
      <div class="order-2 md:order-1">
        <span class="inline-flex items-center gap-2 text-[13px] font-medium text-rt-accent-text bg-rt-accent-quiet border border-rt-accent-line px-3.5 py-1.5 rounded-full mb-6">
          <span class="w-1.5 h-1.5 rounded-full bg-rt-accent shadow-[0_0_8px_var(--accent)]"></span>
          <span data-i18n="hero.eyebrow">Multi-model chat with deliberation</span>
        </span>

        <h1
          class="text-[clamp(2.4rem,5.2vw,4rem)] leading-[1.04] font-extrabold tracking-[-0.03em] mb-6 text-rt-text-1"
          data-i18n="hero.h1"
        >
          Many models. One table. <span class="text-rt-accent-text">The best answer.</span>
        </h1>

        <p class="text-[clamp(1.05rem,1.6vw,1.22rem)] text-rt-text-2 max-w-[52ch] mb-8" data-i18n="hero.lede">
          Roundtable puts the best AI models in one conversation. When the question matters, it convenes
          <strong>The Council</strong>: they propose, debate, vote and synthesize — so you get a deliberated answer, not one model’s guess.
        </p>

        <div class="flex flex-wrap items-center gap-3.5 mb-5">
          <a
            href="https://cloud.r8e.org"
            class="inline-flex items-center gap-2 font-semibold text-[15px] rounded-[10px] px-6 py-3.5 bg-rt-accent text-white hover:bg-rt-accent-hover transition-all duration-200 ease-rt hover:-translate-y-0.5 shadow-[0_0_0_rgba(111,123,242,0)] hover:shadow-[0_8px_30px_rgba(111,123,242,0.32)]"
          >
            <span data-i18n="hero.ctaPrimary">Open Roundtable</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M13 6l6 6-6 6" />
            </svg>
          </a>
          <a
            href="#council"
            class="inline-flex items-center gap-2 font-semibold text-[15px] rounded-[10px] px-6 py-3.5 text-rt-text-1 border border-rt-border-strong hover:border-rt-accent-line hover:bg-rt-accent-quiet transition-all duration-200 ease-rt"
            data-i18n="hero.ctaSecondary"
          >
            See how it works
          </a>
        </div>

        <p class="flex items-center gap-2 text-[13px] text-rt-text-3" data-i18n="hero.note">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 6 9 17l-5-5" />
          </svg>
          Bring your own API keys. They stay encrypted; your data stays yours.
        </p>
      </div>

      <div class="order-1 md:order-2" aria-hidden="true">
        <div class="relative aspect-square max-w-[440px] mx-auto w-full">
          <div class="absolute inset-[12%] border border-rt-border-strong rounded-full"></div>
          <div class="absolute inset-[16%] border border-dashed border-rt-accent-line rounded-full animate-rt-spin"></div>

          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[34%] aspect-square rounded-full grid place-items-center text-center"
            style="background: radial-gradient(circle at 50% 35%, rgba(111,123,242,0.28), rgba(28,30,34,0.9)); border: 1px solid var(--accent-line); box-shadow: 0 0 60px rgba(111,123,242,0.25), inset 0 0 30px rgba(111,123,242,0.12);"
          >
            <span class="text-xs font-semibold text-rt-accent-text leading-tight">
              <strong class="block text-[15px] text-rt-text-1" data-i18n="ring.core">The Council</strong>
              <span data-i18n="ring.coreSub">deliberates</span>
            </span>
          </div>

          {nodes.map((node, i) => {
            const angle = (i * 72 - 90) * (Math.PI / 180);
            const radius = 150;
            const x = Math.cos(angle) * radius;
            const y = Math.sin(angle) * radius;
            return (
              <div
                class="absolute top-1/2 left-1/2 w-14 h-14 -ml-7 -mt-7"
                style={`transform: translate(${x}px, ${y}px);`}
                aria-hidden="true"
              >
                <div
                  class="w-full h-full rounded-[14px] bg-rt-panel border border-rt-border-strong grid place-items-center text-xs font-bold text-rt-text-2 shadow-[0_8px_24px_rgba(0,0,0,0.4)] animate-rt-float"
                  style={`animation-delay: ${node.delay};`}
                >
                  {node.label}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>
