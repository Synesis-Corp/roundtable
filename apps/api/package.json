    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.12.0",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
