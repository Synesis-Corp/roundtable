---
export interface Props {
  class?: string;
  width?: number;
  height?: number;
}

const { class: className = '', width = 28, height = 28 } = Astro.props;
---

<svg
  class={className}
  width={width}
  height={height}
  viewBox="0 0 120 120"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label="Roundtable">
  <defs>
    <radialGradient id="rt-core" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#aab2f9" />
      <stop offset="100%" stop-color="#6f7bf2" />
    </radialGradient>
  </defs>
  <g stroke="rgba(255,255,255,0.16)" stroke-width="2.4">
    <line x1="60" y1="24" x2="60" y2="60" />
    <line x1="94.2" y1="48.9" x2="60" y2="60" />
    <line x1="81.2" y1="89.1" x2="60" y2="60" />
    <line x1="38.8" y1="89.1" x2="60" y2="60" />
    <line x1="25.8" y1="48.9" x2="60" y2="60" />
  </g>
  <circle cx="60" cy="24" r="6.6" fill="#5cb08b" />
  <circle cx="94.2" cy="48.9" r="6.6" fill="#5b91d6" />
  <circle cx="81.2" cy="89.1" r="6.6" fill="#9079ec" />
  <circle cx="38.8" cy="89.1" r="6.6" fill="#cf9a5e" />
  <circle cx="25.8" cy="48.9" r="6.6" fill="#d077a0" />
  <circle cx="60" cy="60" r="13.5" fill="url(#rt-core)" />
  <circle cx="60" cy="60" r="13.5" fill="none" stroke="rgba(255,255,255,0.25)" stroke-width="1.5" />
</svg>
