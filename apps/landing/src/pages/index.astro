---
import Layout from '../layouts/Layout.astro';
import Glow from '../components/Glow.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Providers from '../components/Providers.astro';
import Council from '../components/Council.astro';
import Features from '../components/Features.astro';
import SocialProof from '../components/SocialProof.astro';
import Footer from '../components/Footer.astro';

const title = 'Roundtable — Many models. One table. The best answer.';
const description =
  'Roundtable is a multi-provider AI chat with The Council: several models deliberate in rounds — propose, debate, vote and synthesize — to give you the best answer.';
---

<Layout title={title} description={description}>
  <Glow />
  <Header />
  <main class="relative z-10">
    <Hero />
    <Providers />
    <Council />
    <Features />
    <SocialProof />
    <Footer />
  </main>
</Layout>
