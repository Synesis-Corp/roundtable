---
---

<section class="relative z-10 py-20 md:py-24 overflow-hidden">
  <div class="max-w-wrap mx-auto px-6">
    <div class="max-w-[620px] mx-auto text-center mb-14">
      <p class="text-[13px] font-semibold tracking-[0.06em] uppercase text-rt-accent-text mb-3.5" data-i18n="social.kicker">Open source</p>
      <h2 class="text-[clamp(1.8rem,3.4vw,2.6rem)] leading-[1.1] tracking-[-0.025em] font-bold mb-4" data-i18n="social.h2">
        Built in the open, under AGPL-3.0
      </h2>
      <p class="text-[1.05rem] text-rt-text-2" data-i18n="social.p">
        Roundtable is free software. Self-host it, inspect the code, or contribute back.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 max-w-2xl mx-auto">
      <a
        href="https://github.com/Synesis-Corp/roundtable"
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-5 bg-rt-soft border border-rt-border rounded-2xl p-6 hover:border-rt-accent-line hover:-translate-y-[3px] transition-all duration-300 ease-rt"
      >
        <div class="w-12 h-12 rounded-xl grid place-items-center bg-rt-accent-quiet text-rt-accent-text border border-rt-accent-line shrink-0">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z" />
          </svg>
        </div>
        <div class="text-left">
          <div class="flex items-baseline gap-2">
            <span class="text-3xl font-bold text-rt-text-1" data-stars>—</span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" class="text-yellow-500">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          </div>
          <p class="text-sm text-rt-text-2" data-i18n="social.starsLabel">GitHub stars</p>
        </div>
      </a>

      <div class="flex items-center gap-5 bg-rt-soft border border-rt-border rounded-2xl p-6"
      >
        <div class="w-12 h-12 rounded-xl grid place-items-center bg-rt-accent-quiet text-rt-accent-text border border-rt-accent-line shrink-0">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
        </div>
        <div class="text-left">
          <p class="text-lg font-semibold text-rt-text-1" data-i18n="social.selfHosted">Self-hostable</p>
          <p class="text-sm text-rt-text-2" data-i18n="social.agpl">AGPL-3.0 license</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    (async function fetchStars() {
      try {
        const res = await fetch('https://api.github.com/repos/Synesis-Corp/roundtable', {
          headers: { Accept: 'application/vnd.github+json' },
        });
        if (!res.ok) return;
        const data = await res.json();
        const count = data?.stargazers_count;
        if (typeof count !== 'number') return;
        document.querySelectorAll('[data-stars]').forEach((el) => {
          el.textContent = count.toLocaleString();
        });
      } catch (e) {
        // keep fallback
      }
    })();
  </script>
</section>
