---
const providers = ['OpenAI', 'Anthropic', 'Google', 'DeepSeek', 'Mistral', 'Groq', 'Perplexity', 'OpenRouter'];
---

<section class="relative z-10 py-8">
  <div class="max-w-wrap mx-auto px-6">
    <p class="text-center text-xs tracking-[0.08em] uppercase text-rt-text-3 mb-5" data-i18n="logos.title">Connect the providers you already use</p>
    <div class="flex flex-wrap justify-center gap-3">
      {providers.map((name) => (
        <span class="text-[13px] font-semibold text-rt-text-2 px-3.5 py-1.5 border border-rt-border rounded-full bg-rt-soft hover:text-rt-text-1 hover:border-rt-accent-line transition-colors duration-200 ease-rt">
          {name}
        </span>
      ))}
    </div>
  </div>
</section>
