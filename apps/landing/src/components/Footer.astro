---
import Logo from './Logo.astro';
---

<section class="relative z-10 pt-10 pb-6">
  <div class="max-w-wrap mx-auto px-6">
    <div class="text-center border border-rt-accent-line rounded-3xl px-6 py-16 md:py-20 mb-6"
      style="background: radial-gradient(80% 120% at 50% 0%, rgba(111, 123, 242, 0.18), transparent 70%), var(--bg-soft);"
    >
      <h2 class="text-[clamp(1.8rem,3.4vw,2.6rem)] leading-[1.1] tracking-[-0.025em] font-bold mb-3.5" data-i18n="cta.h2">Take a seat at the table</h2>
      <p class="text-rt-text-2 max-w-[46ch] mx-auto mb-8" data-i18n="cta.p">Connect your first provider and start chatting in under a minute.</p>
      <a
        href="https://cloud.r8e.org"
        class="inline-flex items-center gap-2 font-semibold text-[15px] rounded-[10px] px-7 py-3.5 bg-rt-accent text-white hover:bg-rt-accent-hover transition-all duration-200 ease-rt hover:-translate-y-0.5 shadow-[0_0_0_rgba(111,123,242,0)] hover:shadow-[0_8px_30px_rgba(111,123,242,0.32)]"
      >
        <span data-i18n="cta.btn">Open Roundtable</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>

  <footer class="border-t border-white/[0.075] py-10">
    <div class="max-w-wrap mx-auto px-6">
      <div class="flex flex-col md:flex-row items-center justify-between gap-5">
        <a href="/" class="flex items-center gap-2.5 font-bold text-[15px] text-rt-text-1"
        >
          <Logo width={20} height={20} />
          Roundtable
        </a>

        <div class="flex items-center gap-6">
          <a href="#council" class="text-sm text-rt-text-2 hover:text-rt-text-1 transition-colors duration-200 ease-rt" data-i18n="nav.council">The Council</a>
          <a href="#features" class="text-sm text-rt-text-2 hover:text-rt-text-1 transition-colors duration-200 ease-rt" data-i18n="nav.features">Capabilities</a>
          <a href="https://cloud.r8e.org" class="text-sm text-rt-text-2 hover:text-rt-text-1 transition-colors duration-200 ease-rt" data-i18n="nav.openApp">Open the app</a>
        </div>

        <small class="text-[13px] text-rt-text-3" data-i18n="foot.copyright">© 2026 Roundtable</small>
      </div>
    </div>
  </footer>
</section>
