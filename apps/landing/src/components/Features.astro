---
const features = [
  {
    keyH3: 'card1.h3',
    title: 'Streaming with resume',
    keyP: 'card1.p',
    desc: "Answers arrive token by token. And generation survives navigation: leave and come back, it's still there.",
    icon: 'M13 2 3 14h7l-1 8 10-12h-7z',
  },
  {
    keyH3: 'card2.h3',
    title: 'Encrypted API keys',
    keyP: 'card2.p',
    desc: 'Your keys are stored with AES-256-GCM encryption. Connect the providers you already pay for, no middlemen.',
    icon: 'M7 11V7a5 5 0 0 1 10 0v4M7 11h10a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-8a2 2 0 0 1 2-2z',
  },
  {
    keyH3: 'card3.h3',
    title: 'Web search',
    keyP: 'card3.p',
    desc: 'Models consult the web when needed and cite their sources, like the best tools out there.',
    icon: 'M21 21l-4.3-4.3M11 19a8 8 0 1 0 0-16 8 8 0 0 0 0 16z',
  },
  {
    keyH3: 'card4.h3',
    title: 'Images and PDF',
    keyP: 'card4.p',
    desc: 'Attach images and documents. Routing sends each file to the model that handles it best.',
    icon: 'M3 3h18v18H3zM9 9a2 2 0 1 0 0-4 2 2 0 0 0 0 4zM21 15l-3.5-3.5L9 20',
  },
  {
    keyH3: 'card5.h3',
    title: 'Memory and incognito',
    keyP: 'card5.p',
    desc: 'Remembers what matters across chats — or switch on incognito and nothing from that conversation is saved.',
    icon: 'M12 8V4H8M4 8h16v12H4zM2 14h2M20 14h2M15 13v2M9 13v2',
  },
  {
    keyH3: 'card6.h3',
    title: 'Capability routing',
    keyP: 'card6.p',
    desc: 'Each request goes to the right model, with automatic fallbacks. You choose; the system optimizes.',
    icon: 'M3 12h4l3 8 4-16 3 8h4',
  },
];
---

<section id="features" class="relative z-10 py-20 md:py-24" style="background: linear-gradient(180deg, transparent, rgba(20, 21, 24, 0.6), transparent)">
  <div class="max-w-wrap mx-auto px-6">
    <div class="max-w-[620px] mx-auto text-center mb-14">
      <p class="text-[13px] font-semibold tracking-[0.06em] uppercase text-rt-accent-text mb-3.5" data-i18n="features.kicker">Capabilities</p>
      <h2 class="text-[clamp(1.8rem,3.4vw,2.6rem)] leading-[1.1] tracking-[-0.025em] font-bold mb-4" data-i18n="features.h2">
        Built for real work
      </h2>
      <p class="text-[1.05rem] text-rt-text-2" data-i18n="features.p">
        Streaming, attachments, web search and memory — with privacy and control at the foundation.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((feature) => (
        <div class="bg-rt-soft border border-rt-border rounded-2xl p-7 hover:border-rt-accent-line hover:-translate-y-[3px] hover:bg-rt-panel transition-all duration-300 ease-rt">
          <div class="w-11 h-11 rounded-xl grid place-items-center bg-rt-accent-quiet text-rt-accent-text border border-rt-accent-line mb-5">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d={feature.icon} />
            </svg>
          </div>
          <h3 class="text-base font-semibold mb-2" data-i18n={feature.keyH3}>{feature.title}</h3>
          <p class="text-sm text-rt-text-2 leading-relaxed" data-i18n={feature.keyP}>{feature.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
