#!/bin/sh
# harness pre-commit — enforcement agnostico a la herramienta
#
# Bloquea:
#   - archivos .env reales (permite plantillas *.example / *.docker)
#   - dumps / backups / comprimidos
#   - secretos reales en el contenido (permite placeholders)
# Avisa (no bloquea):
#   - cambios de infraestructura -> recorda sincronizar docs
#
# Bypass intencional y documentado:  git commit --no-verify
#
# Corre igual para cualquier agente AI y para humanos.

staged=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$staged" ] && exit 0

# --- Bloquear archivos .env reales ---
env_offenders=""
for f in $staged; do
  base=$(basename "$f")
  case "$base" in
    *.example|*.docker|*.sample|*.template|*.example.local) : ;;          # plantillas: OK
    .env|.env.*|*.env)        env_offenders="$env_offenders $f" ;;
  esac
done
if [ -n "$env_offenders" ]; then
  echo "[harness] BLOQUEADO: estas intentando commitear archivos .env reales:" >&2
  for f in $env_offenders; do echo "[harness]   - $f" >&2; done
  echo "[harness]   Las variables de entorno son secretas. Versiona solo .env.example / .env.template." >&2
  echo "[harness]   Si es intencional:  git commit --no-verify" >&2
  exit 1
fi

# --- Bloquear dumps / backups / comprimidos ---
dump_offenders=""
for f in $staged; do
  case "$(basename "$f")" in
    *.dump|*.sql.gz|*.backup|*.bak|*.tar.gz|*.tgz|*.zip) dump_offenders="$dump_offenders $f" ;;
  esac
done
if [ -n "$dump_offenders" ]; then
  echo "[harness] BLOQUEADO: dumps/backups/comprimidos no van al repo:" >&2
  for f in $dump_offenders; do echo "[harness]   - $f" >&2; done
  echo "[harness]   Si es intencional (fixture chico):  git commit --no-verify" >&2
  exit 1
fi

# --- Bloquear secretos reales en el contenido (no solo nombres) ---
# Permite placeholders: REPLACE_ME, CHANGE_ME, example, dummy, xxx, your-, <...>, ${...}
#
# Allowlist de falsos positivos (afinada 2026-06-12 y extendida 2026-06-16).
# Cubre patrones legitimos del codebase que la primera regex matchea:
#   - Vocabulario de tokens LLM (inputTokens, outputTokens, maxTokens, ...)
#   - Tipo `token: string`, storage.get("token"), fixtures gho_test / e2e-test / sk-test
#   - Zod schemas: JWT_SECRET: z.string().min(32, ...) — el "valor" es una
#     llamada a schema, no un secreto (env.ts)
#   - Vitest mocks: verifyIdToken: vi.fn() — vi.fn() nunca retorna un valor real
#   - OAuth test mocks: access_token: opts.token.access_token — variable ref,
#     no un token real
#   - Test cookie fixtures: .set('Cookie', 'refreshToken=some-raw-token')
#   - Test variable prefixes: TEST_TOKEN, ORIGINAL_GH_SECRET
#   - Assertions: tokenHash: expect.any(String)
#   - POSTGRES_PASSWORD=postgres (default documentado de compose / ci.yml)
# Un secreto real con valor concreto (api key sk-live, jwt secret real, gho
# real distinto de gho_test, db url con password, un Bearer eyJ... con payload
# real) sigue bloqueado. Override puntual: git commit --no-verify.
secret_hits=""
for f in $staged; do
  case "$(basename "$f")" in
    *.example|*.docker|*.sample|*.template|*.md|*.lock) continue ;;
  esac
  hit=$(git show ":$f" 2>/dev/null | grep -nEi \
    '(sk-[a-z0-9]{16,}|(API_KEY|ACCESS_TOKEN|SECRET|DATABASE_URL|PASSWORD|PRIVATE_KEY|TOKEN)[a-z_]*[[:space:]]*[=:][[:space:]]*[^[:space:]"'"'"']+)' \
    | grep -vEi 'REPLACE_ME|CHANGE_ME|example|dummy|placeholder|xxx|your-|<[a-z_]+>|\$\{|inputTokens|outputTokens|totalTokens|tokensUsed|maxTokens|tokenBudget|tokenCount|estimatedTokens|promptTokens|completionTokens|token[[:space:]]*[?:][[:space:]]*(string|number)|storage\.get|gho_test|e2e-test|sk-test|z\.string\(\)\.(min|max|optional|nullable|email|url|uuid|default|refine|transform)\(|vi\.fn\(|(access_token|refresh_token):[[:space:]]*opts\.|Cookie.*refreshToken=[a-zA-Z0-9_-]+|setCookie.*refreshToken=[a-zA-Z0-9_;-]+|refreshToken:[[:space:]]*\{[[:space:]]*$|(TEST|ORIGINAL)_[A-Z_]+|tokenHash:[[:space:]]*expect\.any\(|POSTGRES_PASSWORD=postgres' || true)
  if [ -n "$hit" ]; then
    secret_hits="$secret_hits\n  $f:\n$(printf '%s' "$hit" | sed 's/^/      /')"
  fi
done
if [ -n "$secret_hits" ]; then
  echo "[harness] BLOQUEADO: posible secreto real en el contenido:" >&2
  printf '%b\n' "$secret_hits" >&2
  echo "[harness]   Usa placeholders (REPLACE_ME, CHANGE_ME) o variables de entorno." >&2
  echo "[harness]   Falso positivo:  git commit --no-verify" >&2
  exit 1
fi

# --- Avisar ante cambios de infraestructura (no bloquea) ---
infra=$(printf '%s\n' "$staged" | grep -Ei 'docker-compose|Dockerfile|\.github/workflows|nginx\.conf|terraform|\.tf$' || true)
if [ -n "$infra" ]; then
  echo "[harness] AVISO: cambio de infraestructura detectado:" >&2
  printf '%s\n' "$infra" | sed 's/^/[harness]   - /' >&2
  echo "[harness]   Recorda sincronizar README / docs / openspec." >&2
fi

exit 0
