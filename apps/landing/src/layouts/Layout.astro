---
export interface Props {
  title: string;
  description: string;
  lang?: 'en' | 'es';
}

const { title, description, lang = 'en' } = Astro.props;
const ogUrl = 'https://r8e.org';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d0e10" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={ogUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <style is:global>
      :root {
        --bg-app: #0d0e10;
        --bg-soft: #141518;
        --bg-panel: #1c1e22;
        --border: rgba(255, 255, 255, 0.075);
        --border-strong: rgba(255, 255, 255, 0.12);
        --text-1: #ededef;
        --text-2: #9a9ea6;
        --text-3: #686c74;
        --accent: #6f7bf2;
        --accent-hover: #818cf6;
        --accent-quiet: rgba(111, 123, 242, 0.14);
        --accent-line: rgba(111, 123, 242, 0.32);
        --accent-text: #aab2f9;
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: 'Inter', system-ui, -apple-system, sans-serif;
        background: var(--bg-app);
        color: var(--text-1);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow-x: hidden;
      }
      ::selection {
        background: var(--accent-line);
        color: #fff;
      }
      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 4px;
      }
      [data-i18n] {
        /* ensures translated HTML is rendered cleanly */
      }
      [data-lang-btn][aria-pressed='true'] {
        color: #fff !important;
        background: var(--accent) !important;
      }
      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        *,
        *::before,
        *::after {
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
  </head>
  <body>
    <slot />

    <script>
      const I18N = {
        en: {
          'nav.council': 'The Council',
          'nav.features': 'Capabilities',
          'nav.openApp': 'Open the app',
          'hero.eyebrow': 'Multi-model chat with deliberation',
          'hero.h1': 'Many models. One table. <span class="text-rt-accent-text">The best answer.</span>',
          'hero.lede':
            'Roundtable puts the best AI models in one conversation. When the question matters, <strong>The Council</strong> convenes: they propose, debate, vote and synthesize — so you get a deliberated answer, not one model’s guess.',
          'hero.ctaPrimary': 'Open Roundtable',
          'hero.ctaSecondary': 'See how it works',
          'hero.note': 'Bring your own API keys. They stay encrypted; your data stays yours.',
          'ring.core': 'The Council',
          'ring.coreSub': 'deliberates',
          'logos.title': 'Connect the providers you already use',
          'council.kicker': 'The difference',
          'council.h2': 'The Council: deliberation, not a single opinion',
          'council.p':
            'For hard questions, several models work through three rounds. Each contributes its strengths; the system synthesizes the strongest answer.',
          'step1.h3': 'Proposals',
          'step1.p':
            'Each model answers separately, with its own perspective and verified sources.',
          'step2.h3': 'Debate',
          'step2.p':
            "They weigh each other's ideas, flag contradictions and rescue the strongest arguments.",
          'step3.h3': 'Vote',
          'step3.p':
            'Each votes with a confidence level and points out the main risk of the decision.',
          'step4.h3': 'Synthesis',
          'step4.p':
            'A final answer that incorporates the best of the table — clear and actionable.',
          'features.kicker': 'Capabilities',
          'features.h2': 'Built for real work',
          'features.p':
            'Streaming, attachments, web search and memory — with privacy and control at the foundation.',
          'card1.h3': 'Streaming with resume',
          'card1.p':
            "Answers arrive token by token. And generation survives navigation: leave and come back, it's still there.",
          'card2.h3': 'Encrypted API keys',
          'card2.p':
            'Your keys are stored with AES-256-GCM encryption. Connect the providers you already pay for, no middlemen.',
          'card3.h3': 'Web search',
          'card3.p':
            'Models consult the web when needed and cite their sources, like the best tools out there.',
          'card4.h3': 'Images and PDF',
          'card4.p':
            'Attach images and documents. Routing sends each file to the model that handles it best.',
          'card5.h3': 'Memory and incognito',
          'card5.p':
            'Remembers what matters across chats — or switch on incognito and nothing from that conversation is saved.',
          'card6.h3': 'Capability routing',
          'card6.p':
            'Each request goes to the right model, with automatic fallbacks. You choose; the system optimizes.',
          'social.kicker': 'Open source',
          'social.h2': 'Built in the open, under AGPL-3.0',
          'social.p':
            'Roundtable is free software. Self-host it, inspect the code, or contribute back.',
          'social.starsLabel': 'GitHub stars',
          'social.agpl': 'AGPL-3.0 license',
          'social.selfHosted': 'Self-hostable',
          'cta.h2': 'Take a seat at the table',
          'cta.p': 'Connect your first provider and start chatting in under a minute.',
          'cta.btn': 'Open Roundtable',
          'foot.copyright': '© 2026 Roundtable',
        },
        es: {
          'nav.council': 'El Consejo',
          'nav.features': 'Capacidades',
          'nav.openApp': 'Abrir la app',
          'hero.eyebrow': 'Chat multimodelo con deliberación',
          'hero.h1':
            'Varios modelos. Una mesa. <span class="text-rt-accent-text">La mejor respuesta.</span>',
          'hero.lede':
            'Roundtable reúne a los mejores modelos de IA en una misma conversación. Cuando la pregunta importa, convoca a <strong>El Consejo</strong>: proponen, debaten, votan y sintetizan — para darte una respuesta deliberada, no la opinión de un solo modelo.',
          'hero.ctaPrimary': 'Abrir Roundtable',
          'hero.ctaSecondary': 'Ver cómo funciona',
          'hero.note': 'Usa tus propias API keys. Se almacenan cifradas; tus datos son tuyos.',
          'ring.core': 'El Consejo',
          'ring.coreSub': 'delibera',
          'logos.title': 'Conecta los proveedores que ya usas',
          'council.kicker': 'El diferencial',
          'council.h2': 'El Consejo: deliberación, no una sola opinión',
          'council.p':
            'Para las preguntas difíciles, varios modelos trabajan en tres rondas. Cada uno aporta sus fortalezas; el sistema sintetiza la respuesta más sólida.',
          'step1.h3': 'Propuestas',
          'step1.p': 'Cada modelo responde por separado, con su perspectiva y fuentes verificadas.',
          'step2.h3': 'Debate',
          'step2.p':
            'Evalúan las ideas ajenas, marcan contradicciones y rescatan los mejores argumentos.',
          'step3.h3': 'Voto',
          'step3.p':
            'Cada uno vota con un nivel de confianza y señala el riesgo principal de la decisión.',
          'step4.h3': 'Síntesis',
          'step4.p': 'Una respuesta final que incorpora lo mejor de la mesa — clara y accionable.',
          'features.kicker': 'Capacidades',
          'features.h2': 'Hecho para trabajo real',
          'features.p':
            'Streaming, adjuntos, búsqueda web y memoria — con privacidad y control como base.',
          'card1.h3': 'Streaming con resume',
          'card1.p':
            'Las respuestas llegan token a token. Y la generación sobrevive a la navegación: te vas y vuelves, y sigue ahí.',
          'card2.h3': 'API keys cifradas',
          'card2.p':
            'Tus claves se guardan con cifrado AES-256-GCM. Conecta los proveedores que ya pagas, sin intermediarios.',
          'card3.h3': 'Búsqueda web',
          'card3.p':
            'Los modelos consultan la web cuando hace falta y citan las fuentes, al estilo de las mejores herramientas.',
          'card4.h3': 'Imágenes y PDF',
          'card4.p':
            'Adjunta imágenes y documentos. El routing manda cada archivo al modelo que mejor lo procesa.',
          'card5.h3': 'Memoria e incógnito',
          'card5.p':
            'Recuerda lo importante entre chats — o activa el modo incógnito y no guarda nada de esa conversación.',
          'card6.h3': 'Routing por capacidades',
          'card6.p':
            'Cada petición va al modelo adecuado, con respaldos automáticos. Tú eliges; el sistema optimiza.',
          'social.kicker': 'Open source',
          'social.h2': 'Construido en abierto, bajo AGPL-3.0',
          'social.p':
            'Roundtable es software libre. Autoalójalo, inspecciona el código o contribuye.',
          'social.starsLabel': 'estrellas en GitHub',
          'social.agpl': 'Licencia AGPL-3.0',
          'social.selfHosted': 'Autoalojable',
          'cta.h2': 'Siéntate a la mesa',
          'cta.p': 'Conecta tu primer proveedor y empieza a chatear en menos de un minuto.',
          'cta.btn': 'Abrir Roundtable',
          'foot.copyright': '© 2026 Roundtable',
        },
      };

      const TITLES = {
        en: 'Roundtable — Many models. One table. The best answer.',
        es: 'Roundtable — Varios modelos. Una mesa. La mejor respuesta.',
      };

      function applyLang(lang) {
        const dict = I18N[lang] || I18N.en;
        document.documentElement.lang = lang;
        document.title = TITLES[lang];
        document.querySelectorAll('[data-i18n]').forEach((el) => {
          const val = dict[el.getAttribute('data-i18n')];
          if (val != null) el.innerHTML = val;
        });
        document.querySelectorAll('[data-lang-btn]').forEach((b) => {
          b.setAttribute('aria-pressed', String(b.dataset.langBtn === lang));
        });
        try {
          localStorage.setItem('r8e-lang', lang);
        } catch (e) {}
      }

      const saved = (() => {
        try {
          return localStorage.getItem('r8e-lang');
        } catch (e) {
          return null;
        }
      })();
      const initial =
        saved || ((navigator.language || 'en').toLowerCase().startsWith('es') ? 'es' : 'en');
      applyLang(initial);

      document.querySelectorAll('[data-lang-btn]').forEach((b) => {
        b.addEventListener('click', () => applyLang(b.dataset.langBtn));
      });
    </script>
  </body>
</html>
