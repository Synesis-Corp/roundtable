    "@chat/providers": "workspace:*",
    "@chat/router": "workspace:*",
    "@chat/sdk": "workspace:*",
    "ai": "^4.0.0",
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.5.1",
    "google-auth-library": "^10.7.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2",
    "pdfkit": "^0.15.0",
