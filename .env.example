# ── Roundtable Environment ───────────────────────────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.
#
# Docker: docker compose picks up these variables automatically.
# Native dev: pnpm dev uses this file from the monorepo root (see vite.config.ts).

# PostgreSQL — Docker uses postgres:5432, native dev uses localhost:5432.
# The default DB name remains `chatia` for existing volumes after the rebrand.
DATABASE_URL="postgresql://postgres:postgres@postgres:5432/chatia?schema=public"
# For native dev without Docker:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/roundtable?schema=public"

# JWT — minimum 32 characters. Generate: openssl rand -hex 32
JWT_SECRET="change-this-to-a-secure-random-string-min-32-chars"

# Encryption — minimum 32 chars (secret) and 16 chars (salt)
ENCRYPTION_SECRET="another-secure-random-string-min-32-chars"
ENCRYPTION_SALT="change-this-to-a-secure-random-salt-min-16-chars"

# Server
PORT=4000

# CORS — allowed origins for the web frontend
WEB_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3000"

# Google OAuth — get yours at https://console.cloud.google.com/apis/credentials
# Add authorized origins: http://localhost, http://localhost:3000
# Add authorized redirect URIs: http://localhost, http://localhost:3000
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"

# GitHub OAuth — create at https://github.com/settings/developers
# Register a new OAuth App with:
#   Homepage URL:                  http://localhost
#   Authorization callback URL:    http://localhost/api/auth/github/callback
# GITHUB_CLIENT_ID is the public "Client ID" (safe to expose to the browser).
# GITHUB_CLIENT_SECRET is the "Client secret" — NEVER commit it, set in
# .env (gitignored) or via your secrets manager in prod.
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Frontend — VITE_* variables are exposed to the browser bundle
# Must match GOOGLE_CLIENT_ID but with VITE_ prefix
VITE_GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
# Set VITE_GITHUB_ENABLED=true to render the "Continue with GitHub" button
# in LoginPage and RegisterPage. Defaults to true (opt-out) so the button
# shows out of the box; set explicitly to "false" to hide it. Note: if the
# button is shown but GITHUB_CLIENT_ID / GITHUB_CLIENT_SECRET are not set,
# clicking it will return a 503 with "GitHub sign-in is not configured".
VITE_GITHUB_ENABLED="true"

# Admin Dashboard — comma-separated list of emails with admin access to /admin.
# When unset or empty, no user is admin. Only aggregated metrics are shown — zero PII.
# Example: ADMIN_EMAILS="admin@example.com,owner@example.com"
ADMIN_EMAILS=""
